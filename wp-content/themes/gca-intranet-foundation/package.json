{
  "name": "gca-intranet-foundation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm-run-all css:sass js:copygovuk-frontend js:minifygovuk-frontend",
    "watch": "sass --watch assets/scss/theme.scss assets/dist/gca-theme.css --style=expanded --load-path=node_modules --quiet-deps",
    "css:sass": "sass assets/scss/theme.scss assets/dist/gca-theme.css --style=compressed --load-path=node_modules --quiet-deps",
    "js:copygovuk-frontend": "shx mkdir -p assets/scripts && shx cp node_modules/govuk-frontend/dist/govuk/govuk-frontend.min.js assets/scripts/all.js",
    "js:minifygovuk-frontend": "./node_modules/.bin/babel ./node_modules/govuk-frontend/dist/govuk/govuk-frontend.min.js --out-file assets/scripts/all.min.js --presets=@babel/preset-env --minified"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@babel/cli": "^7.10.5",
    "@babel/core": "^7.11.1",
    "@babel/preset-env": "^7.11.0",
    "sass": "^1.97.3"
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "ccs-frontend": "^2.5.0",
    "govuk-frontend": "^5.4.0",
    "npm-run-all": "^4.1.3",
    "shx": "^0.2.2"
  }
}
