# --------------------------------------------------
# Playwright Docker Test Environment
# --------------------------------------------------

WP_DRIVER=docker

# Path to the docker-compose project
WP_DOCKER_CWD=/path/to/gca-Intranet

# WordPress service name in docker compose
WP_SERVICE=wordpress

PARALLEL_LOCAL=false

# Playwright base URL
PW_BASE_URL=http://localhost:8080


# --------------------------------------------------
# Test Database (used ONLY during docker test runs)
# --------------------------------------------------

REQUIRE_TEST_DB=true

WP_DB_HOST=db:3306
WP_DB_NAME=gca_intranet_test
WP_DB_USER=gca_test_user
WP_DB_PASSWORD=your_password_here


# --------------------------------------------------
# Local Docker MySQL (dev stack)
# --------------------------------------------------

DB_NAME=gca_intranet_test
DB_USER=gca_test_user
DB_PASSWORD=your_password_here
DB_ROOT_PASSWORD=changeme_root
DB_HOST=db:3306


# --------------------------------------------------
# WordPress runtime settings
# --------------------------------------------------

WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
WP_URL=http://localhost:8080


# --------------------------------------------------
# WordPress init container settings
# --------------------------------------------------

WP_TITLE=GCA Intranet (E2E)
WP_ADMIN_USER=adminuser
WP_ADMIN_PASSWORD=change-me-strong
WP_ADMIN_EMAIL=adminuser@example.com
WP_THEME=gca-intranet